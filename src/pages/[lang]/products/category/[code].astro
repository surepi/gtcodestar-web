---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmptyState from "@/components/EmptyState.astro";
import ProductCard from "@/components/ProductCard.astro";
import ProductCategorySidebar from "@/components/ProductCategorySidebar.astro";
import ProductsHero from "@/components/ProductsHero.astro";
import {
  apiGet,
  apiGetAllContentSummaries,
  apiGetFallback,
  productCategoryChildren,
  type Category,
  type SiteData,
} from "@/lib/api";
import { PREFIXED_LOCALES, apiLang, isLocale, t } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const lang of PREFIXED_LOCALES) {
    const categories = await apiGet<Category[]>(`/api/categories/tree?lang=${apiLang(lang)}`);
    const fallbackCategories = categories.length > 0 ? categories : await apiGet<Category[]>(`/api/categories/tree?lang=en`);
    for (const category of productCategoryChildren(fallbackCategories)) {
      paths.push({ params: { lang, code: category.code }, props: { category } });
    }
  }
  return paths;
}

const { lang } = Astro.params;
if (!isLocale(lang)) return Astro.redirect("/");
const { category } = Astro.props;
const backendLang = apiLang(lang);
const prefix = `/${lang}`;
const [siteData, categories, products] = await Promise.all([
  apiGetFallback<SiteData>(`/api/site?lang=${backendLang}`, `/api/site?lang=en`),
  apiGetFallback<Category[]>(`/api/categories/tree?lang=${backendLang}`, `/api/categories/tree?lang=en`, (items) => items.length === 0),
  apiGetAllContentSummaries(`/api/products?lang=${backendLang}&scode=${category.code}`),
]);
const productCategories = productCategoryChildren(categories);
---

<BaseLayout siteData={siteData} categories={categories} title={`${category.name} | Gtcodestar Barcode Scanners`}>
  <ProductsHero
    eyebrow={t(lang, "product.category")}
    title={category.name}
    description={`${products.total} ${t(lang, "products.count")} ${t(lang, "category.available")}`}
    searchLang={backendLang}
    prefix={prefix}
    scode={category.code}
    searchTitle={`${t(lang, "search")} ${category.name}`}
    searchPlaceholder={t(lang, "search.category.placeholder")}
  />
  <section class="section">
    <div class="container product-layout">
      <ProductCategorySidebar categories={productCategories} title={t(lang, "categories")} allLabel={t(lang, "all.products")} prefix={prefix} activeCode={category.code} />
      <div>
        <div class="list-head">
          <div>
            <p class="eyebrow">{t(lang, "models")}</p>
            <h2>{products.total} {t(lang, "products.count")}</h2>
          </div>
          <a class="button secondary" href={`${prefix}/contact/`}>{t(lang, "request.quote")}</a>
        </div>
        {
          products.items.length > 0 ? (
            <div class="grid three product-grid">
              {products.items.map((product) => <ProductCard product={product} prefix={prefix} />)}
            </div>
          ) : (
            <EmptyState
              title={t(lang, "empty.products.title")}
              description={t(lang, "empty.products.desc")}
              actionHref={`${prefix}/contact/`}
              actionLabel={t(lang, "request.quote")}
            />
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .product-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 28px;
  }

  .list-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 24px;
  }

  @media (max-width: 920px) {
    .product-layout {
      grid-template-columns: 1fr;
    }

    .list-head {
      display: grid;
      align-items: start;
    }
  }
</style>
