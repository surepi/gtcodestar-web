---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmptyState from "@/components/EmptyState.astro";
import NewsCard from "@/components/NewsCard.astro";
import Pagination from "@/components/Pagination.astro";
import { apiGet, apiGetFallback, type Category, type ContentSummary, type PageResult, type SiteData } from "@/lib/api";
import { PREFIXED_LOCALES, apiLang, isLocale, t } from "@/lib/i18n";
import { numberedPages, pageCount } from "@/lib/pagination";

const pageSize = 9;

export async function getStaticPaths() {
  const paths = [];
  const staticPageSize = 9;
  for (const lang of PREFIXED_LOCALES) {
    const backendLang = apiLang(lang);
    const news = await apiGet<PageResult<ContentSummary>>(`/api/news?lang=${backendLang}&page=1&pageSize=1`);
    for (const page of numberedPages(news.total, staticPageSize).filter((item) => item > 1)) {
      paths.push({ params: { lang, page: String(page) } });
    }
  }
  return paths;
}

const { lang } = Astro.params;
if (!isLocale(lang)) return Astro.redirect("/");
const currentPage = Number(Astro.params.page || "1");
const backendLang = apiLang(lang);
const prefix = `/${lang}`;
const [siteData, categories, news] = await Promise.all([
  apiGetFallback<SiteData>(`/api/site?lang=${backendLang}`, `/api/site?lang=en`),
  apiGetFallback<Category[]>(`/api/categories/tree?lang=${backendLang}`, `/api/categories/tree?lang=en`, (items) => items.length === 0),
  apiGet<PageResult<ContentSummary>>(`/api/news?lang=${backendLang}&page=${currentPage}&pageSize=${pageSize}`),
]);
const totalPages = pageCount(news.total, pageSize);
---

<BaseLayout siteData={siteData} categories={categories} title={`${t(lang, "news")} ${t(lang, "page")} ${currentPage}`}>
  <section class="section band">
    <div class="container">
      <p class="eyebrow">{t(lang, "news")}</p>
      <h1>{t(lang, "company.updates")}</h1>
    </div>
  </section>
  <section class="section">
    <div class="container">
      {
        news.items.length > 0 ? (
          <div class="grid three">
            {news.items.map((item) => <NewsCard item={item} prefix={prefix} />)}
          </div>
        ) : (
          <EmptyState title={t(lang, "empty.news.title")} description={t(lang, "empty.news.desc")} />
        )
      }
      <Pagination basePath={`${prefix}/news/`} currentPage={currentPage} totalPages={totalPages} locale={lang} />
    </div>
  </section>
</BaseLayout>
