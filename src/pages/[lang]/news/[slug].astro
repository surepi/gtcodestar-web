---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RelatedNews from "@/components/RelatedNews.astro";
import { apiGet, apiGetAllContentSummaries, apiGetCached, apiGetFallback, apiGetSoftFallback, apiTryGet, contentHref, imageURL, type Category, type ContentDetail, type ContentSummary, type MetaData, type PageResult, type SiteData } from "@/lib/api";
import { cleanAltText, cleanText, formatDate } from "@/lib/content";
import { contentDocHtml } from "@/lib/content-server";
import { PREFIXED_LOCALES, apiLang, isLocale, t } from "@/lib/i18n";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const paths = [];
  for (const lang of PREFIXED_LOCALES) {
    const backendLang = apiLang(lang);
    const news = await apiGetAllContentSummaries(`/api/news?lang=${backendLang}`);
    for (const item of news.items) {
      const detail = await apiTryGet<ContentDetail>(`/api/news/${item.id}?lang=${backendLang}`);
      if (!detail) continue;
      paths.push({
        params: { lang, slug: `${item.filename || item.id}-${item.id}` },
        props: { id: item.id },
      });
    }
  }
  return paths;
}

const { lang } = Astro.params;
if (!isLocale(lang)) return Astro.redirect("/");
const { id } = Astro.props;
const backendLang = apiLang(lang);
const prefix = `/${lang}`;
const [siteData, categories, article, meta, latestNews] = await Promise.all([
  apiGetFallback<SiteData>(`/api/site?lang=${backendLang}`, `/api/site?lang=en`),
  apiGetFallback<Category[]>(`/api/categories/tree?lang=${backendLang}`, `/api/categories/tree?lang=en`, (items) => items.length === 0),
  apiGetCached<ContentDetail>(`/api/news/${id}?lang=${backendLang}`),
  apiGetSoftFallback<MetaData>(`/api/seo/contents/${id}?lang=${backendLang}`, `/api/seo/contents/${id}?lang=en`),
  apiGet<PageResult<ContentSummary>>(`/api/news?lang=${backendLang}&page=1&pageSize=4`),
]);
const image = imageURL(article.icon);
const title = cleanText(article.title);
const articleContentHtml = contentDocHtml(article.doc);
const relatedNews = latestNews.items.filter((item) => item.id !== article.id).slice(0, 3);
const [enArticle, zhArticle] = await Promise.all([
  backendLang === "en" ? article : apiTryGet<ContentDetail>(`/api/news/${id}?lang=en`),
  backendLang === "cn" ? article : apiTryGet<ContentDetail>(`/api/news/${id}?lang=cn`),
]);
const localeLinks = {
  en: enArticle ? contentHref("news", enArticle) : "/news/",
  "zh-hans": zhArticle ? `/zh-hans${contentHref("news", zhArticle)}` : "/zh-hans/news/",
};
---

<BaseLayout siteData={siteData} categories={categories} meta={meta} localeLinks={localeLinks}>
  <section class="section band">
    <div class="container article-head">
      <p class="eyebrow">{t(lang, "news")}</p>
      <h1>{title}</h1>
      <time>{formatDate(article.date)}</time>
    </div>
  </section>
  {image && (
    <section class="article-image">
      <Image src={image} alt={cleanAltText(title)} width={1180} height={664} />
    </section>
  )}
  <section class="section">
    <article class="container content" set:html={articleContentHtml} />
  </section>
  <RelatedNews title={t(lang, "related.news")} backHref={`${prefix}/news/`} backLabel={t(lang, "back.news")} items={relatedNews} prefix={prefix} />
</BaseLayout>

<style>
  .article-head {
    display: grid;
    gap: 16px;
  }

  time {
    color: var(--muted);
    font-weight: 700;
  }

  .article-image {
    max-width: 1180px;
    margin: 48px auto 0;
    padding: 0 48px;
  }

  .article-image img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    border-radius: 8px;
  }

  .content {
    max-width: 900px;
  }

  .content :global(img) {
    height: auto;
  }

  @media (max-width: 820px) {
    .article-image {
      padding: 0 20px;
    }
  }
</style>
