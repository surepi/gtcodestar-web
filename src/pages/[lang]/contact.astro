---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.astro";
import { apiGetFallback, type Category, type SiteData } from "@/lib/api";
import { PREFIXED_LOCALES, apiLang, isLocale, t } from "@/lib/i18n";

export function getStaticPaths() {
  return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) return Astro.redirect("/");
const backendLang = apiLang(lang);
const [siteData, categories] = await Promise.all([
  apiGetFallback<SiteData>(`/api/site?lang=${backendLang}`, `/api/site?lang=en`),
  apiGetFallback<Category[]>(`/api/categories/tree?lang=${backendLang}`, `/api/categories/tree?lang=en`, (items) => items.length === 0),
]);
---

<BaseLayout siteData={siteData} categories={categories} title={t(lang, "contact")}>
  <section class="section band">
    <div class="container">
      <p class="eyebrow">{t(lang, "contact")}</p>
      <h1>{t(lang, "contact.sales")}</h1>
      <p>{siteData.company.name}</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid two">
      <div class="contact-block">
        <h2>{t(lang, "company.information")}</h2>
        {siteData.company.address && <p>{siteData.company.address}</p>}
        {siteData.company.phone && <p><a href={`tel:${siteData.company.phone}`}>{siteData.company.phone}</a></p>}
        {siteData.company.email && <p><a href={`mailto:${siteData.company.email}`}>{siteData.company.email}</a></p>}
      </div>
      <ContactForm lang={backendLang} />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-block {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .contact-block a {
    color: var(--primary);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
