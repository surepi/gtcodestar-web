---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.astro";
import { apiGet, DEFAULT_LANG, type Category, type SiteData } from "@/lib/api";

const lang = DEFAULT_LANG;
const [siteData, categories] = await Promise.all([
  apiGet<SiteData>(`/api/site?lang=${lang}`),
  apiGet<Category[]>(`/api/categories/tree?lang=${lang}`),
]);
---

<BaseLayout siteData={siteData} categories={categories} title="Contact">
  <section class="section band">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Contact sales</h1>
      <p>{siteData.company.name}</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid two">
      <div class="contact-block">
        <h2>Company information</h2>
        {siteData.company.address && <p>{siteData.company.address}</p>}
        {siteData.company.phone && <p><a href={`tel:${siteData.company.phone}`}>{siteData.company.phone}</a></p>}
        {siteData.company.email && <p><a href={`mailto:${siteData.company.email}`}>{siteData.company.email}</a></p>}
      </div>
      <ContactForm lang="en" />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-block {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .contact-block a {
    color: var(--primary);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
