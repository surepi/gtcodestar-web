---
import { LOCALES, type Locale } from "@/lib/i18n";

type Props = {
  homeHref: string;
  logoSrc: string;
  logoAlt: string;
  navItems: { href: string; label: string; active: boolean; icon: string[] }[];
  regionLabels: Record<Locale, string>;
  currentLocale: Locale;
  languageHref: (locale: Locale) => string;
  companyName: string;
};

const {
  homeHref,
  logoSrc,
  logoAlt,
  navItems,
  regionLabels,
  currentLocale,
  languageHref,
  companyName,
} = Astro.props;
---

<header class="site-header">
  <a class="brand" href={homeHref}>
    {logoSrc ? <img src={logoSrc} alt={logoAlt} width="720" height="83" decoding="async" fetchpriority="high" /> : <span>Gtcodestar</span>}
  </a>
  <nav class="main-nav" aria-label="Main navigation">
    {navItems.map((item) => (
      <a href={item.href} class={item.active ? "active" : ""}>
        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={item.icon.join("")} />
        <span>{item.label}</span>
      </a>
    ))}
  </nav>
  <div class="header-actions">
    <details class="lang-menu">
      <summary>
        <span>{regionLabels[currentLocale]}</span>
        <svg class="lang-menu-chevron" viewBox="0 0 24 24" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="lang-menu-panel">
        {LOCALES.map((locale) => (
          <a class={locale === currentLocale ? "active" : ""} href={languageHref(locale)} aria-current={locale === currentLocale ? "true" : undefined}>
            <span>{regionLabels[locale]}</span>
            <small>{locale === "zh-hans" ? "CN" : "GLOBAL"}</small>
          </a>
        ))}
      </div>
    </details>
    <details class="mobile-nav">
      <summary aria-label="Open navigation">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <nav aria-label="Mobile navigation">
        <div class="mobile-menu-brand">
          {logoSrc ? <img src={logoSrc} alt={logoAlt} width="720" height="83" loading="lazy" decoding="async" /> : <span>{companyName}</span>}
        </div>
        {navItems.map((item) => (
          <a href={item.href} class={item.active ? "active" : ""}>
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={item.icon.join("")} />
            <span>{item.label}</span>
          </a>
        ))}
        {LOCALES.map((locale) => <a class={locale === currentLocale ? "active" : ""} href={languageHref(locale)}>{regionLabels[locale]}</a>)}
      </nav>
    </details>
  </div>
</header>

<script>
  const closeHeaderMenus = () => {
    document.querySelectorAll<HTMLDetailsElement>(".site-header details[open]").forEach((details) => {
      details.open = false;
    });
  };

  document.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target : null;
    if (!target) return;
    if (target.closest(".site-header details a")) {
      closeHeaderMenus();
      return;
    }
    document.querySelectorAll<HTMLDetailsElement>(".site-header details[open]").forEach((details) => {
      if (!details.contains(target)) details.open = false;
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeHeaderMenus();
  });

  document.addEventListener("astro:after-swap", closeHeaderMenus);
</script>

<style is:global>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 70px;
    width: 100%;
    padding: 0 40px;
    border-bottom: 1px solid rgba(17, 24, 39, 0.05);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: all 0.3s ease;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    font-weight: 800;
  }

  .brand img {
    width: 150px;
    height: auto;
    aspect-ratio: 720 / 83;
    max-height: 40px;
    object-fit: contain;
    transition: transform 0.25s ease;
  }

  .brand:hover img {
    transform: scale(1.05);
  }

  .brand span {
    font-size: 18px;
    font-weight: 900;
    letter-spacing: 0;
    background: linear-gradient(135deg, var(--color-foreground) 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .main-nav {
    display: flex;
    justify-content: center;
    justify-self: center;
    gap: 8px;
    color: var(--color-foreground);
    font-size: 14px;
    font-weight: 600;
  }

  .main-nav a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    color: var(--color-muted-foreground);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .nav-icon {
    width: 16px;
    height: 16px;
    flex: 0 0 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .main-nav a:hover,
  .main-nav a.active {
    color: var(--color-primary);
    background: rgba(11, 114, 217, 0.06);
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 12px;
  }

  .lang-menu {
    position: relative;
  }

  .lang-menu summary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 38px;
    min-width: 86px;
    padding: 0 14px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.66);
    backdrop-filter: blur(10px);
    color: var(--color-muted-foreground);
    cursor: pointer;
    font-size: 13px;
    font-weight: 750;
    list-style: none;
    transition: all 0.2s ease;
  }

  .lang-menu summary::-webkit-details-marker {
    display: none;
  }

  .lang-menu summary:hover,
  .lang-menu[open] summary {
    border-color: rgba(11, 114, 217, 0.24);
    background: #ffffff;
    color: var(--color-primary);
  }

  .lang-menu summary:focus-visible {
    outline: 2px solid rgba(11, 114, 217, 0.28);
    outline-offset: 2px;
  }

  .lang-menu-chevron {
    width: 12px;
    height: 12px;
    color: var(--color-muted-foreground);
    transition: transform 0.2s ease;
  }

  .lang-menu[open] .lang-menu-chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  .lang-menu-panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 156px;
    padding: 6px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: var(--radius-control);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(20px);
    box-shadow: 0 16px 35px -12px rgba(15, 23, 42, 0.22);
    display: grid;
    gap: 2px;
    z-index: 100;
  }

  .lang-menu-panel a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-height: 36px;
    padding: 0 10px;
    border-radius: calc(var(--radius-control) - 4px);
    color: var(--color-muted-foreground);
    font-size: 13px;
    font-weight: 650;
    transition: all 0.18s ease;
  }

  .lang-menu-panel small {
    color: var(--color-muted-foreground);
    font-size: 11px;
    font-weight: 800;
  }

  .lang-menu-panel a:hover,
  .lang-menu-panel a.active {
    background: rgba(11, 114, 217, 0.07);
    color: var(--color-primary);
  }

  .lang-menu-panel a.active small {
    color: var(--color-primary);
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 820px) {
    .site-header {
      min-height: 64px;
      padding: 0 20px;
      grid-template-columns: auto 1fr;
    }

    .brand {
      justify-self: start;
    }

    .main-nav {
      display: none;
    }

    .header-actions {
      justify-self: end;
    }

    .lang-menu {
      display: none;
    }

    .mobile-nav {
      display: block;
      position: relative;
    }

    .mobile-nav summary {
      display: grid;
      place-items: center;
      align-content: center;
      gap: 4px;
      width: 40px;
      height: 40px;
      border: 1px solid rgba(17, 24, 39, 0.08);
      border-radius: 999px;
      background: var(--color-background);
      cursor: pointer;
      list-style: none;
      transition: all 0.25s ease;
    }

    .mobile-nav summary:hover {
      border-color: var(--color-primary);
      background: rgba(11, 114, 217, 0.04);
    }

    .mobile-nav summary::-webkit-details-marker {
      display: none;
    }

    .mobile-nav summary span {
      width: 18px;
      height: 2px;
      border-radius: 999px;
      background: var(--color-foreground);
      transition: all 0.25s ease;
    }

    .mobile-nav nav {
      position: absolute;
      top: 52px;
      right: 0;
      display: grid;
      min-width: 260px;
      padding: 8px;
      border: 1px solid rgba(17, 24, 39, 0.08);
      border-radius: var(--radius-card);
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 12px 36px rgba(0, 0, 0, 0.1);
      z-index: 100;
      gap: 4px;
    }

    .mobile-menu-brand {
      display: flex;
      align-items: center;
      min-height: 48px;
      padding: 8px 12px 12px;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      margin-bottom: 4px;
    }

    .mobile-menu-brand img {
      width: 140px;
      height: auto;
      aspect-ratio: 720 / 83;
      object-fit: contain;
    }

    .mobile-menu-brand span {
      color: var(--color-foreground);
      font-size: 15px;
      font-weight: 800;
    }

    .mobile-nav nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-radius: var(--radius-control);
      color: var(--color-muted-foreground);
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s ease;
    }

    .mobile-nav nav a:hover,
    .mobile-nav nav a.active {
      background: rgba(11, 114, 217, 0.06);
      color: var(--color-primary);
    }

    .mobile-nav nav a .nav-icon {
      width: 17px;
      height: 17px;
      flex-basis: 17px;
    }
  }
</style>
