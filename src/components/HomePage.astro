---
import ProductCard from "@/components/ProductCard.astro";
import NewsCard from "@/components/NewsCard.astro";
import { Image } from "astro:assets";
import { categoryHref, imageURL, productCategoryChildren, type Category, type ContentSummary, type PageResult, type SiteData } from "@/lib/api";
import { cleanAltText, cleanSummary, cleanText } from "@/lib/content";
import { t, type Locale } from "@/lib/i18n";

type Props = {
  siteData: SiteData;
  categories: Category[];
  products: PageResult<ContentSummary>;
  news: PageResult<ContentSummary>;
  lang: Locale;
  prefix?: string;
  heroTitle?: string;
  companyLead?: string;
};

const {
  siteData,
  categories,
  products,
  news,
  lang,
  prefix = "",
  heroTitle = siteData.site.title,
  companyLead = siteData.company.address,
} = Astro.props;
const heroProducts = products.items.filter((item) => imageURL(item.icon)).slice(0, 3);
const primaryHeroProduct = heroProducts[0];
const productCategories = productCategoryChildren(categories).slice(0, 6);
const fallbackCategoryImages = products.items.filter((item) => imageURL(item.icon));
const categoryTiles = productCategories.map((category, index) => {
  const representative = products.items.find((product) => product.scode === category.code && imageURL(product.icon)) || fallbackCategoryImages[index % Math.max(fallbackCategoryImages.length, 1)];
  return {
    category,
    image: representative ? imageURL(representative.icon) : "",
    productCount: products.items.filter((product) => product.scode === category.code).length,
  };
});
const featuredSeries = products.items.slice(0, 3);
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy-block">
      <div class="badge fade-up" style="animation-delay: 0.1s">
        <span class="badge-dot"></span>
        <p class="badge-text">{t(lang, "barcode.manufacturer")}</p>
      </div>
      <h1 class="fade-up" style="animation-delay: 0.2s">{heroTitle}</h1>
      <p class="hero-copy fade-up" style="animation-delay: 0.3s">{siteData.site.description}</p>
      <div class="hero-actions fade-up" style="animation-delay: 0.4s">
        <a class="button premium-btn" href={`${prefix}/products/`}>
          <span>{t(lang, "view.products")}</span>
          <svg viewBox="0 0 24 24" class="btn-icon"><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a class="button secondary" href={`${prefix}/contact/`}>{t(lang, "contact.sales")}</a>
      </div>
    </div>
    <div class="hero-product-panel fade-up" style="animation-delay: 0.25s" aria-label={t(lang, "featured.products.label")}>
      {primaryHeroProduct ? (
        <a class="hero-main-product" href={`${prefix}/product/${primaryHeroProduct.filename || primaryHeroProduct.id}-${primaryHeroProduct.id}/`}>
          <div class="glow-bg"></div>
          <div class="card-grid-pattern"></div>
          <Image
            src={imageURL(primaryHeroProduct.icon)}
            alt={cleanAltText(primaryHeroProduct.title)}
            width={900}
            height={675}
            loading="eager"
            fetchpriority="high"
          />
          <div class="product-info">
            <span class="tag">{t(lang, "featured.model")}</span>
            <strong>{cleanText(primaryHeroProduct.title)}</strong>
          </div>
        </a>
      ) : null}
      {heroProducts.length > 1 && (
        <div class="hero-mini-products">
          {heroProducts.slice(1).map((product) => (
            <a class="mini-product-card" href={`${prefix}/product/${product.filename || product.id}-${product.id}/`}>
              <div class="card-grid-pattern"></div>
              <Image src={imageURL(product.icon)} alt={cleanAltText(product.title)} width={160} height={160} loading="eager" />
              <div class="mini-info">
                <span>{cleanSummary(product.title, 48)}</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<section class="section products-section">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t(lang, "products")}</p>
        <h2>{t(lang, "product.categories.title")}</h2>
      </div>
      <a class="button secondary" href={`${prefix}/products/`}>{t(lang, "all.products")}</a>
    </div>
    {
      categoryTiles.length > 0 && (
        <div class="category-showcase">
          {categoryTiles.map(({ category, image, productCount }, index) => (
            <a class={`category-tile tile-span-${(index === 0 || index === 3 || index === 5) ? '2' : '1'}`} href={`${prefix}${categoryHref(category)}`}>
              <span class="tile-index">{String(index + 1).padStart(2, '0')}</span>
              <div class="tile-content">
                <span class="count-badge">{productCount > 0 ? `${productCount} ${t(lang, "scanner.models")}` : t(lang, "product.category")}</span>
                <h3>{cleanText(category.name)}</h3>
                <p class="desc">{t(lang, "category.available")}</p>
                <strong class="link-btn">
                  <span>{t(lang, "view.details")}</span>
                  <svg viewBox="0 0 24 24" class="link-icon"><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
                </strong>
              </div>
              {image && (
                <div class="tile-image-wrapper">
                  <Image src={image} alt={cleanAltText(category.name)} width={360} height={360} loading="lazy" />
                </div>
              )}
            </a>
          ))}
        </div>
      )
    }
    {
      featuredSeries.length > 0 && (
        <div class="series-block">
          <div class="series-head">
            <div>
              <p class="eyebrow">{t(lang, "featured.series")}</p>
              <h3>{t(lang, "featured.scanners")}</h3>
            </div>
          </div>
          <div class="grid three product-grid">
            {featuredSeries.map((product) => <ProductCard product={product} prefix={prefix} />)}
          </div>
        </div>
      )
    }
  </div>
</section>

<section class="section band company-section">
  <div class="container company-panel">
    <div class="company-main">
      <div class="company-info-block">
        <p class="eyebrow">{t(lang, "company")}</p>
        <h2>{siteData.company.name}</h2>
        <p class="lead">{companyLead}</p>
      </div>
      <div class="capability-grid">
        <div class="cap-card">
          <div class="cap-icon-box">
            <svg viewBox="0 0 24 24" class="cap-icon"><path fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <strong>{t(lang, "capability.supply.title")}</strong>
          <span>{t(lang, "capability.supply.desc")}</span>
        </div>
        <div class="cap-card">
          <div class="cap-icon-box">
            <svg viewBox="0 0 24 24" class="cap-icon"><path fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <strong>{t(lang, "capability.oem.title")}</strong>
          <span>{t(lang, "capability.oem.desc")}</span>
        </div>
        <div class="cap-card">
          <div class="cap-icon-box">
            <svg viewBox="0 0 24 24" class="cap-icon"><path fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <strong>{t(lang, "contact")}</strong>
          <span>{siteData.company.email || siteData.company.phone || siteData.company.address}</span>
        </div>
      </div>
    </div>
    <div class="brand-stats">
      <div class="stat-item">
        <span class="stat-number">15M+</span>
        <span class="stat-label">{t(lang, "stat.global.users")}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">100+</span>
        <span class="stat-label">{t(lang, "stat.countries")}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">15+</span>
        <span class="stat-label">{t(lang, "stat.years")}</span>
      </div>
    </div>
  </div>
</section>

<section class="section news-section">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t(lang, "news")}</p>
        <h2>{t(lang, "latest.updates")}</h2>
      </div>
    </div>
    <div class="grid three">
      {news.items.map((item) => <NewsCard item={item} prefix={prefix} />)}
    </div>
    <div class="section-foot">
      <a class="more-link" href={`${prefix}/news/`}>
        <span>{t(lang, "view.news")}</span>
        <svg viewBox="0 0 24 24" class="more-icon"><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    align-items: center;
    min-height: 620px;
    padding: 108px 32px 64px;
    background: linear-gradient(180deg, #f8fbff 0%, #ffffff 72%);
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(15, 23, 42, 0.055);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(15, 23, 42, 0.02) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
    z-index: 1;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: min(1120px, calc(100% - 48px));
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(11, 114, 217, 0.18), transparent);
    transform: translateX(-50%);
    z-index: 1;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(400px, 0.9fr);
    gap: 60px;
    align-items: center;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(11, 114, 217, 0.05);
    border: 1px solid rgba(11, 114, 217, 0.12);
    padding: 6px 16px;
    border-radius: 99px;
    backdrop-filter: blur(8px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #0b72d9;
    box-shadow: 0 0 10px #0b72d9;
    animation: pulseDot 2s infinite;
  }

  @keyframes pulseDot {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.8);
    }
  }

  .badge-text {
    margin: 0;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0b72d9;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero h1 {
    font-size: clamp(38px, 4.4vw, 56px);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: 0;
    background: linear-gradient(135deg, #0f172a 10%, #1e3a8a 50%, #0b72d9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 24px 0;
  }

  .hero-copy {
    max-width: 580px;
    margin: 0;
    color: #475569;
    font-size: 17px;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }

  .premium-btn {
    position: relative;
    overflow: hidden;
    gap: 8px;
    background: linear-gradient(135deg, #0b72d9 0%, #05509e 100%);
    box-shadow: 0 10px 24px rgba(11, 114, 217, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    border: none;
    border-radius: 12px;
    padding: 0 24px;
    min-height: 48px;
    font-weight: 600;
  }

  .premium-btn:hover {
    box-shadow: 0 12px 30px rgba(11, 114, 217, 0.35);
    transform: translateY(-2px);
  }

  .premium-btn::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 45%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 55%
    );
    transform: rotate(-45deg);
    transition: transform 0.6s ease;
    opacity: 0;
  }

  .premium-btn:hover::after {
    transform: translate(50%, 50%) rotate(-45deg);
    opacity: 1;
  }

  .btn-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.25s ease;
  }

  .premium-btn:hover .btn-icon {
    transform: translateX(4px);
  }

  .button.secondary {
    border-radius: 12px;
    padding: 0 24px;
    min-height: 48px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(10px);
    color: #1e293b;
    font-weight: 600;
  }

  .button.secondary:hover {
    background: #ffffff;
    border-color: rgba(11, 114, 217, 0.3);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.04);
    transform: translateY(-1px);
  }

  .hero-product-panel {
    display: grid;
    gap: 18px;
    position: relative;
    z-index: 2;
  }

  .hero-main-product {
    display: grid;
    gap: 18px;
    padding: 32px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(24px);
    box-shadow:
      0 30px 60px -15px rgba(15, 23, 42, 0.08),
      0 1px 3px rgba(0, 0, 0, 0.02),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
    position: relative;
    overflow: hidden;
    animation: float 6s ease-in-out infinite;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  .hero-main-product::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(11,114,217,0.15) 40%, rgba(11,114,217,0.02) 80%, rgba(255,255,255,0.5));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .card-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(11, 114, 217, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(11, 114, 217, 0.02) 1px, transparent 1px);
    background-size: 14px 14px;
    pointer-events: none;
    opacity: 0.5;
    z-index: 0;
  }

  .glow-bg {
    position: absolute;
    width: 250px;
    height: 250px;
    top: -80px;
    right: -80px;
    background: linear-gradient(135deg, rgba(11, 114, 217, 0.12), rgba(11, 114, 217, 0));
    pointer-events: none;
    transition: transform 0.8s ease;
    z-index: 0;
  }

  .hero-main-product:hover .glow-bg {
    transform: scale(1.4);
  }

  .hero-main-product:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 40px 80px -15px rgba(15, 23, 42, 0.14);
    border-color: rgba(11, 114, 217, 0.2);
  }

  .hero-main-product img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    padding: 20px;
    border-radius: 10px;
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    box-shadow: 0 10px 30px -5px rgba(15, 23, 42, 0.04);
    position: relative;
    z-index: 1;
    transition: transform 0.5s ease;
  }

  .hero-main-product:hover img {
    transform: scale(1.03) translateY(-4px);
  }

  .product-info {
    display: grid;
    gap: 8px;
    position: relative;
    z-index: 1;
  }

  .tag {
    align-self: start;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0b72d9;
    background: rgba(11, 114, 217, 0.08);
    padding: 4px 10px;
    border-radius: 6px;
    width: fit-content;
  }

  .hero-main-product strong {
    font-size: 21px;
    line-height: 1.25;
    color: #0f172a;
    font-weight: 800;
  }

  .hero-mini-products {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .mini-product-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 18px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(16px);
    box-shadow:
      0 4px 20px rgba(0,0,0,0.01),
      inset 0 1px 0 rgba(255,255,255,0.5);
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mini-product-card .card-grid-pattern {
    opacity: 0.25;
  }

  .mini-product-card:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: rgba(11, 114, 217, 0.2);
    background: #ffffff;
    box-shadow: 0 15px 30px rgba(15, 23, 42, 0.06);
  }

  .mini-product-card img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    padding: 4px;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.03);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .mini-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .mini-info span {
    color: #0f172a;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .section {
    padding: 84px 32px;
    position: relative;
    border-top: 1px solid rgba(15, 23, 42, 0.055);
  }

  .section.band {
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.9) 0%, #ffffff 100%);
  }

  .products-section {
    background: #ffffff;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .company-section {
    padding-top: 92px;
    padding-bottom: 92px;
    background:
      linear-gradient(180deg, #f6f9fc 0%, #ffffff 100%);
    border-top-color: rgba(11, 114, 217, 0.1);
  }

  .news-section {
    background:
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  }

  .company-section::before,
  .news-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: min(1120px, calc(100% - 48px));
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(11, 114, 217, 0.24), transparent);
    transform: translateX(-50%);
  }

  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 36px;
  }

  .section-foot {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 44px;
  }

  .more-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-size: 15px;
    font-weight: 700;
    transition: all 0.3s ease;
    position: relative;
    padding-bottom: 4px;
    cursor: pointer;
  }

  .more-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .more-link:hover::after {
    transform: scaleX(1);
  }

  .more-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.25s ease;
  }

  .more-link:hover .more-icon {
    transform: translateX(4px);
  }

  .eyebrow {
    margin: 0 0 12px;
    color: #0b72d9;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 12px;
    height: 2px;
    background: #0b72d9;
    border-radius: 2px;
  }

  .section-head h2 {
    font-size: clamp(27px, 3.2vw, 34px);
    font-weight: 900;
    color: #0f172a;
    letter-spacing: 0;
    line-height: 1.15;
  }

  .category-showcase {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .category-tile {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 42%;
    gap: 20px;
    align-items: center;
    min-height: 232px;
    overflow: hidden;
    padding: 30px;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 12px;
    background: rgba(248, 250, 252, 0.65);
    backdrop-filter: blur(10px);
    position: relative;
