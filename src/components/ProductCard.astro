---
import { contentHref, imageURL, type ContentSummary } from "@/lib/api";
import { cleanAltText, cleanSummary, cleanText } from "@/lib/content";
import { Image } from "astro:assets";

type Props = {
  product: ContentSummary;
  prefix?: string;
};

const { product, prefix = "" } = Astro.props;
const image = imageURL(product.icon);
const title = cleanText(product.title);
const summary = cleanSummary(product.description || product.subtitle, 170);
---

<article class="card product-card">
  <a href={`${prefix}${contentHref("product", product)}`}>
    <div class="product-media">
      {image ? (
        <Image class="product-image" src={image} alt={cleanAltText(title)} width={480} height={360} loading="lazy" />
      ) : (
        <div class="product-placeholder-glow"></div>
      )}
    </div>
    <div class="card-body">
      <h3>{title}</h3>
      <p>{summary || ' '}</p>
    </div>
  </a>
</article>

<style>
  .product-card {
    height: 100%;
  }

  .product-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-media {
    display: grid;
    place-items: center;
    height: 220px;
    background: var(--bg-soft);
    overflow: hidden;
    position: relative;
  }

  .product-image {
    max-width: 90%;
    max-height: 80%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.05) translateY(-2px);
  }

  .product-placeholder-glow {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(11, 114, 217, 0.03) 0%, rgba(99, 102, 241, 0.05) 100%);
    position: relative;
  }

  .product-placeholder-glow::before {
    content: 'SCANNER';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.25em;
    color: var(--primary);
    opacity: 0.12;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 20px;
    gap: 12px;
  }

  h3 {
    font-size: 17px;
    line-height: 1.3;
    color: var(--text-main);
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    min-height: 48px;
  }

  p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 13px;
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    min-height: 42px;
  }

</style>
