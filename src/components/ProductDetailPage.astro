---
import { Image } from "astro:assets";

import ProductCard from "@/components/ProductCard.astro";
import type { ContentDetail, ContentSummary } from "@/lib/api";
import { cleanAltText } from "@/lib/content";
import { t, type Locale } from "@/lib/i18n";

type Props = {
  lang: Locale;
  prefix: string;
  product: ContentDetail;
  title: string;
  image: string;
  gallery: string[];
  summary: string;
  quoteHref: string;
  contentHtml: string;
  relatedProducts: ContentSummary[];
};

const { lang, prefix, product, title, image, gallery, summary, quoteHref, contentHtml, relatedProducts } = Astro.props;
---

<section class="section band">
  <div class="container detail-hero">
    <div>
      <p class="eyebrow">{t(lang, "product")}</p>
      <h1>{title}</h1>
      {summary && <p>{summary}</p>}
      <div class="detail-actions">
        <a class="button" href={quoteHref}>{t(lang, "request.quote")}</a>
        <a class="button secondary" href={`${prefix}/products/`}>{t(lang, "back.products")}</a>
      </div>
    </div>
    {image && <Image src={image} alt={cleanAltText(title)} width={840} height={630} />}
  </div>
</section>
{
  gallery.length > 0 && (
    <section class="section gallery-section">
      <div class="container">
        <p class="eyebrow">{t(lang, "gallery")}</p>
        <div class="gallery-grid">
          {gallery.map((item) => <Image src={item} alt={cleanAltText(title)} width={480} height={360} loading="lazy" />)}
        </div>
      </div>
    </section>
  )
}
<section class="section">
  <div class="container detail-grid">
    <article>
      <div class="content" set:html={contentHtml} />
    </article>
    <aside class="specs">
      <div class="quote-card">
        <p class="eyebrow">{t(lang, "request.quote")}</p>
        <h2>{t(lang, "quote.card.title")}</h2>
        <p>{t(lang, "quote.card.copy")}</p>
        <a class="button" href={quoteHref}>{t(lang, "ask.pricing")}</a>
      </div>
      <h2>{t(lang, "details")}</h2>
      <div class="spec-row">
        <span>{t(lang, "category")}</span>
        <strong>{product.scode}</strong>
      </div>
    </aside>
  </div>
</section>
{
  relatedProducts.length > 0 && (
    <section class="section related-section band">
      <div class="container">
        <div class="related-head">
          <div>
            <p class="eyebrow">{t(lang, "products")}</p>
            <h2>{t(lang, "related.products")}</h2>
          </div>
          <a class="button secondary" href={`${prefix}/products/category/${encodeURIComponent(product.scode)}/`}>
            {t(lang, "view.products")}
          </a>
        </div>
        <div class="grid four related-grid">
          {relatedProducts.map((item) => <ProductCard product={item} prefix={prefix} />)}
        </div>
      </div>
    </section>
  )
}

<style>
  .detail-hero {
    display: grid;
    grid-template-columns: 1.2fr 420px;
    gap: 48px;
    align-items: center;
  }

  .detail-hero img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .gallery-section {
    padding-bottom: 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .gallery-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: contain;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 40px;
    align-items: start;
  }

  .content :global(img) {
    height: auto;
    margin: 0 auto;
  }

  .content :global(table) {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }

  .specs {
    display: grid;
    gap: 12px;
    position: sticky;
    top: 96px;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .quote-card {
    display: grid;
    gap: 12px;
    margin: -20px -20px 8px;
    padding: 20px;
    border-bottom: 1px solid var(--line);
    border-radius: 8px 8px 0 0;
    background: var(--band);
  }

  .quote-card p {
    margin: 0;
  }

  .spec-row {
    display: grid;
    gap: 4px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }

  .spec-row span {
    color: var(--muted);
    text-transform: capitalize;
  }

  .related-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 26px;
  }

  .grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media (max-width: 920px) {
    .detail-hero,
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .specs {
      position: static;
    }

    .gallery-grid,
    .grid.four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .related-head {
      display: grid;
      align-items: start;
    }

    .grid.four {
      grid-template-columns: 1fr;
    }
  }
</style>
