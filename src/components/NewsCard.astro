---
import { contentHref, imageURL, type ContentSummary } from "@/lib/api";
import { cleanAltText, cleanPreferredSummary, cleanText, formatDate } from "@/lib/content";
import { Image } from "astro:assets";

type Props = {
  item: ContentSummary;
  prefix?: string;
};

const { item, prefix = "" } = Astro.props;
const image = imageURL(item.icon);
const title = cleanText(item.title);
const summary = cleanPreferredSummary([item.description, item.subtitle], 150);
---

<article class="card news-card">
  <a href={`${prefix}${contentHref("news", item)}`}>
    <div class="news-media">
      {image ? (
        <Image class="news-image" src={image} alt={cleanAltText(title)} width={640} height={360} loading="lazy" />
      ) : (
        <div class="news-placeholder-glow"></div>
      )}
    </div>
    <div class="card-body">
      <time>{formatDate(item.date)}</time>
      <h3>{title}</h3>
      <p>{summary || ' '}</p>
    </div>
  </a>
</article>

<style>
  .news-card a {
    display: grid;
    height: 100%;
  }

  .news-media {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    overflow: hidden;
    position: relative;
  }

  .news-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: transparent;
    transition: transform 0.5s ease;
  }

  .news-card:hover .news-image {
    transform: scale(1.05);
  }

  .news-placeholder-glow {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(11, 114, 217, 0.04) 0%, rgba(99, 102, 241, 0.07) 100%);
    position: relative;
  }

  .news-placeholder-glow::before {
    content: 'NEWS';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.25em;
    color: var(--primary);
    opacity: 0.15;
  }

  time {
    display: block;
    margin-bottom: 12px;
    color: var(--primary);
    font-size: 12px;
    font-weight: 900;
  }

  h3 {
    font-size: 17px;
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    min-height: 46px;
  }

  p {
    margin: 12px 0 0;
    color: var(--text-secondary);
    font-size: 13px;
    line-height: 1.55;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    min-height: 60px;
  }
</style>
