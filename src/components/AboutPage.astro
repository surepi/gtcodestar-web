---
import type { ContentDetail } from "@/lib/api";
import { contentDocHtml } from "@/lib/content-server";
import { t, type Locale } from "@/lib/i18n";

type Props = {
  page: ContentDetail;
  lang: Locale;
};

const { page, lang } = Astro.props;
---

<section class="about-hero">
  <div class="container hero-inner">
    <p class="eyebrow fade-up" style="animation-delay: 0.1s">{t(lang, "about")}</p>
    <h1 class="fade-up" style="animation-delay: 0.2s">{page.title}</h1>
    <p class="hero-copy fade-up" style="animation-delay: 0.3s">{page.description}</p>
  </div>
</section>
<section class="section">
  <div class="container content" set:html={contentDocHtml(page.doc)} />
</section>

<style>
  .about-hero {
    display: grid;
    align-items: center;
    text-align: center;
    padding: 120px 20px 80px;
    background: var(--surface);
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-hero h1 {
    font-size: 56px;
    font-weight: 800;
    letter-spacing: 0;
    margin: 16px auto;
  }

  .hero-copy {
    font-size: 20px;
    color: var(--text-secondary);
  }

  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-up {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .content :global(img) {
    height: auto;
    border-radius: 16px;
    margin: 32px auto;
  }

  @media (max-width: 820px) {
    .about-hero {
      padding: 80px 20px 40px;
    }

    .about-hero h1 {
      font-size: 40px;
    }
  }
</style>
