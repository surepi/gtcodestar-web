---
import { categoryHref, type SiteData, type Category } from "@/lib/api";
import { t, type Locale } from "@/lib/i18n";

type Props = {
  siteData: SiteData;
  logoSrc: string;
  logoAlt: string;
  productCategories: Category[];
  currentLocale: Locale;
  navPrefix: string;
  footerCopyrightHtml: string;
};

const {
  siteData,
  logoSrc,
  logoAlt,
  productCategories,
  currentLocale,
  navPrefix,
  footerCopyrightHtml,
} = Astro.props;
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <strong class="brand-name">
          {siteData.site.logo ? (
            <img src={logoSrc} alt={logoAlt} class="footer-logo" width="720" height="83" loading="lazy" decoding="async" />
          ) : (
            <span>{siteData.company.name}</span>
          )}
        </strong>
        <p class="brand-desc">{siteData.site.description}</p>
        <div class="social-links">
          <span aria-label="Twitter" class="social-btn" role="img">
            <svg viewBox="0 0 24 24" class="icon"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </span>
          <span aria-label="LinkedIn" class="social-btn" role="img">
            <svg viewBox="0 0 24 24" class="icon"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg>
          </span>
          <span aria-label="GitHub" class="social-btn" role="img">
            <svg viewBox="0 0 24 24" class="icon"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </span>
        </div>
      </div>

      <div class="footer-nav-col">
        <span class="footer-title">{t(currentLocale, "contact")}</span>
        <ul class="contact-list">
          {siteData.company.email && (
            <li>
              <a href={`mailto:${siteData.company.email}`} class="contact-item">
                <svg viewBox="0 0 24 24" class="contact-icon"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 6l-10 7L2 6"/></svg>
                <span>{siteData.company.email}</span>
              </a>
            </li>
          )}
          {siteData.company.phone && (
            <li>
              <a href={`tel:${siteData.company.phone}`} class="contact-item">
                <svg viewBox="0 0 24 24" class="contact-icon"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>{siteData.company.phone}</span>
              </a>
            </li>
          )}
          {siteData.company.address && (
            <li class="contact-item non-link">
              <svg viewBox="0 0 24 24" class="contact-icon"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
              <span>{siteData.company.address}</span>
            </li>
          )}
          {siteData.company.contact && (
            <li class="contact-item non-link">
              <svg viewBox="0 0 24 24" class="contact-icon"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2"/></svg>
              <span>{siteData.company.contact}</span>
            </li>
          )}
        </ul>
      </div>

      {productCategories.length > 0 && (
        <div class="footer-nav-col">
          <span class="footer-title">{t(currentLocale, "categories")}</span>
          <ul class="footer-link-list">
            {productCategories.slice(0, 5).map((item) => (
              <li>
                <a href={`${navPrefix}${categoryHref(item)}`}>{item.name}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <div class="footer-bottom">
      <div class="footer-copyright">
        {footerCopyrightHtml ? (
          <span set:html={footerCopyrightHtml} />
        ) : (
          <span>&copy; {new Date().getFullYear()} {siteData.company.name}. All rights reserved.</span>
        )}
      </div>
      {siteData.config.icp && (
        <div class="footer-icp">
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">
            {siteData.config.icp}
          </a>
        </div>
      )}
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    --footer-bg: #090d16;
    --footer-text: #94a3b8;
    --footer-text-light: #cbd5e1;
    --footer-heading: #ffffff;
    --footer-border: rgba(255, 255, 255, 0.07);
    --footer-border-glow: rgba(56, 189, 248, 0.15);
    --footer-accent: var(--color-primary);
    --footer-accent-rgb: 11, 114, 217;

    position: relative;
    background:
      radial-gradient(circle at 50% 0%, rgba(15, 23, 42, 0.8) 0%, var(--footer-bg) 100%),
      var(--footer-bg);
    border-top: 1px solid var(--footer-border);
    color: var(--footer-text);
    padding: 72px 0 40px 0;
    font-size: 14px;
    line-height: 1.6;
    overflow: hidden;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(56, 189, 248, 0.3) 50%, transparent);
    pointer-events: none;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: 64px;
    padding-bottom: 48px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .brand-name {
    display: flex;
    align-items: center;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0;
    color: var(--footer-heading);
    background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .footer-logo {
    width: 170px;
    height: auto;
    aspect-ratio: 720 / 83;
    max-height: 45px;
    object-fit: contain;
  }

  .brand-desc {
    margin: 0;
    color: var(--footer-text);
    line-height: 1.7;
    font-size: 14px;
    max-width: 360px;
  }

  .social-links {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  .social-btn {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--footer-text);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .social-btn .icon {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer-title {
    display: block;
    margin-bottom: 24px;
    color: var(--footer-heading);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
  }

  .footer-title::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 20px;
    height: 2px;
    background: var(--footer-accent);
    border-radius: 2px;
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .footer-link-list a {
    text-decoration: none;
    color: var(--footer-text);
    font-weight: 500;
    display: inline-block;
    transition: all 0.25s ease;
  }

  .footer-link-list a:hover {
    color: var(--footer-heading);
    transform: translateX(4px);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--footer-text);
    transition: color 0.25s ease;
  }

  a.contact-item:hover {
    color: var(--footer-heading);
  }

  .contact-item span {
    line-height: 1.4;
  }

  .contact-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--footer-accent);
    transition: transform 0.25s ease;
  }

  a.contact-item:hover .contact-icon {
    transform: scale(1.1);
  }

  .contact-item.non-link {
    align-items: flex-start;
    cursor: default;
  }

  .contact-item.non-link .contact-icon {
    margin-top: 3px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid var(--footer-border);
    font-size: 13px;
    color: #64748b;
  }

  .footer-copyright span {
    color: #64748b;
  }

  .footer-icp a {
    color: #64748b;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer-icp a:hover {
    color: var(--footer-heading);
  }

  @media (max-width: 980px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 56px 0 32px 0;
    }
    .footer-container {
      padding: 0 20px;
    }
    .footer-main {
      grid-template-columns: 1fr;
      gap: 36px;
      padding-bottom: 36px;
    }
    .footer-brand {
      grid-column: span 1;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
      padding-top: 24px;
    }
  }
</style>
